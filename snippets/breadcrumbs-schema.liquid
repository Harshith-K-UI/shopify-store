{%- comment -%}
  BreadcrumbList JSON-LD schema for SEO.
  Renders breadcrumb structured data based on page type.
{%- endcomment -%}

{%- if request.page_type == 'product' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ request.origin }}"
        }
        {%- if product.collections.size > 0 -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ product.collections.first.title | json }},
            "item": "{{ request.origin }}{{ product.collections.first.url }}"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }},
            "item": "{{ request.origin }}{{ product.url }}"
          }
        {%- else -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": {{ product.title | json }},
            "item": "{{ request.origin }}{{ product.url }}"
          }
        {%- endif -%}
      ]
    }
  </script>

