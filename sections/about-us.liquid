{%- style -%}
  /* ============================================
     ABOUT US — TFI-BANISA Premium Dark Aesthetic
     ============================================ */

  .about-page {
    --about-dark: #111111;
    --about-navy: #1a1a2e;
    --about-accent: #e8e8e8;
    --about-muted: #999999;
    --about-white: #ffffff;
    --about-surface: #0f0f0f;
  }

  /* --- HERO --- */
  .about-hero {
    text-align: center;
    padding: 100px 0 80px;
    background: var(--about-dark);
    color: var(--about-white);
    position: relative;
    overflow: hidden;
  }

  .about-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(ellipse at center top, rgba(255,255,255,0.03) 0%, transparent 70%);
    pointer-events: none;
  }

  .about-hero__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--about-muted);
    margin-bottom: 24px;
  }

  .about-hero__title {
    font-size: 5.5rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.05;
    margin-bottom: 28px;
    color: var(--about-white);
  }

  .about-hero__subtitle {
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--about-muted);
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* --- STAT BAR --- */
  .about-stats {
    background: var(--about-navy);
    padding: 50px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .about-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    text-align: center;
  }

  .about-stat {
    padding: 20px 16px;
    position: relative;
  }

  .about-stat + .about-stat::before {
    content: '';
    position: absolute;
    left: 0;
    top: 25%;
    height: 50%;
    width: 1px;
    background: rgba(255,255,255,0.1);
  }

  .about-stat__number {
    font-size: 3rem;
    font-weight: 900;
    color: var(--about-white);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .about-stat__label {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--about-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  /* --- STORY SECTIONS --- */
  .about-story {
    padding: 90px 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .about-story--dark {
    background: var(--about-dark);
    color: var(--about-white);
    border-bottom-color: rgba(255,255,255,0.06);
  }

  .about-story__inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .about-story__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 20px;
  }

  .about-story--dark .about-story__eyebrow {
    color: var(--about-muted);
  }

  .about-story:not(.about-story--dark) .about-story__eyebrow {
    color: #888888;
  }

  .about-story__heading {
    font-size: 3.2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1.1;
    margin-bottom: 36px;
  }

  .about-story__text {
    font-size: 1.5rem;
    line-height: 1.85;
    text-align: left;
  }

  .about-story--dark .about-story__text {
    color: rgba(255,255,255,0.7);
  }

  .about-story:not(.about-story--dark) .about-story__text {
    color: #444444;
  }

  .about-story__text p {
    margin-bottom: 20px;
  }

  .about-story__text p:last-child {
    margin-bottom: 0;
  }

  /* --- DECORATIVE QUOTE BLOCK --- */
  .about-quote {
    margin-top: 50px;
    padding: 40px 0;
    border-top: 2px solid rgba(255,255,255,0.08);
    text-align: center;
  }

  .about-story:not(.about-story--dark) .about-quote {
    border-top-color: rgba(0,0,0,0.08);
  }

  .about-quote__text {
    font-size: 2rem;
    font-weight: 700;
    font-style: italic;
    line-height: 1.4;
    max-width: 600px;
    margin: 0 auto;
  }

  .about-story--dark .about-quote__text {
    color: rgba(255,255,255,0.85);
  }

  .about-story:not(.about-story--dark) .about-quote__text {
    color: #222222;
  }

  /* --- VALUES / MISSION --- */
  .about-values {
    background: var(--about-dark);
    color: var(--about-white);
    padding: 100px 0;
  }

  .about-values__title {
    font-size: 3rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-align: center;
    margin-bottom: 64px;
    color: var(--about-white);
  }

  .about-values__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .about-value-card {
    padding: 48px 36px;
    text-align: center;
    position: relative;
    border: 1px solid rgba(255,255,255,0.06);
    transition: background 0.3s ease;
  }

  .about-value-card:hover {
    background: rgba(255,255,255,0.03);
  }

  .about-value-card__icon {
    font-size: 3.2rem;
    margin-bottom: 24px;
    display: block;
  }

  .about-value-card__title {
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 16px;
    color: var(--about-white);
  }

  .about-value-card__text {
    font-size: 1.4rem;
    line-height: 1.75;
    color: var(--about-muted);
  }

  /* --- CTA --- */
  .about-cta {
    background: var(--about-white);
    color: var(--about-dark);
    padding: 100px 0;
    text-align: center;
  }

  .about-cta__heading {
    font-size: 3.2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 20px;
    color: var(--about-dark);
  }

  .about-cta__text {
    font-size: 1.5rem;
    line-height: 1.75;
    color: #666666;
    max-width: 580px;
    margin: 0 auto 40px;
  }

  .about-cta__button {
    display: inline-block;
    background: var(--about-dark);
    color: var(--about-white);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    font-size: 1.3rem;
    padding: 18px 56px;
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid var(--about-dark);
  }

  .about-cta__button:hover {
    background: transparent;
    color: var(--about-dark);
  }

  /* --- RESPONSIVE --- */
  @media screen and (max-width: 749px) {
    .about-hero {
      padding: 70px 0 50px;
    }

    .about-hero__title {
      font-size: 3.2rem;
    }

    .about-hero__subtitle {
      font-size: 1.4rem;
    }

    .about-stats__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
    }

    .about-stat {
      padding: 20px 12px;
    }

    .about-stat:nth-child(3)::before,
    .about-stat:nth-child(1)::before {
      display: none;
    }

    .about-stat__number {
      font-size: 2.2rem;
    }

    .about-story {
      padding: 60px 0;
    }

    .about-story__heading {
      font-size: 2.2rem;
    }

    .about-story__text {
      font-size: 1.4rem;
    }

    .about-quote__text {
      font-size: 1.6rem;
    }

    .about-values {
      padding: 60px 0;
    }

    .about-values__title {
      font-size: 2.2rem;
      margin-bottom: 40px;
    }

    .about-values__grid {
      grid-template-columns: 1fr;
    }

    .about-cta {
      padding: 60px 0;
    }

    .about-cta__heading {
      font-size: 2.2rem;
    }
  }
{%- endstyle -%}

{%- comment -%} ====== HERO ====== {%- endcomment -%}
<div class="about-hero">
  <div class="page-width">
    <div class="about-hero__eyebrow">{{ section.settings.hero_eyebrow }}</div>
    <h1 class="about-hero__title">{{ section.settings.hero_title }}</h1>
    <p class="about-hero__subtitle">{{ section.settings.hero_subtitle }}</p>
  </div>
</div>

{%- comment -%} ====== STAT BAR ====== {%- endcomment -%}
<div class="about-stats">
  <div class="page-width">
    <div class="about-stats__grid">
      <div class="about-stat">
        <div class="about-stat__number">{{ section.settings.stat_1_value }}</div>
        <div class="about-stat__label">{{ section.settings.stat_1_label }}</div>
      </div>
      <div class="about-stat">
        <div class="about-stat__number">{{ section.settings.stat_2_value }}</div>
        <div class="about-stat__label">{{ section.settings.stat_2_label }}</div>
      </div>
      <div class="about-stat">
        <div class="about-stat__number">{{ section.settings.stat_3_value }}</div>
        <div class="about-stat__label">{{ section.settings.stat_3_label }}</div>
      </div>
      <div class="about-stat">
        <div class="about-stat__number">{{ section.settings.stat_4_value }}</div>
        <div class="about-stat__label">{{ section.settings.stat_4_label }}</div>
      </div>
    </div>
  </div>
</div>

{%- comment -%} ====== CONTENT BLOCKS ====== {%- endcomment -%}
{%- for block in section.blocks -%}
  {%- case block.type -%}

    {%- when 'story_block' -%}
      <div class="about-story {% if block.settings.dark_background %}about-story--dark{% endif %}" {{ block.shopify_attributes }}>
        <div class="page-width">
          <div class="about-story__inner">
            <div class="about-story__eyebrow">{{ block.settings.eyebrow }}</div>
            <h2 class="about-story__heading">{{ block.settings.heading }}</h2>
            <div class="about-story__text rte">{{ block.settings.text }}</div>
            {%- if block.settings.quote != blank -%}
              <div class="about-quote">
                <p class="about-quote__text">"{{ block.settings.quote }}"</p>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>

    {%- when 'values' -%}
      <div class="about-values" {{ block.shopify_attributes }}>
        <div class="page-width">
          <h2 class="about-values__title">{{ block.settings.heading }}</h2>
          <div class="about-values__grid">
            {%- for i in (1..3) -%}
              {%- assign title_key = 'value_' | append: i | append: '_title' -%}
              {%- assign text_key = 'value_' | append: i | append: '_text' -%}
              {%- assign icon_key = 'value_' | append: i | append: '_icon' -%}
              {%- if block.settings[title_key] != blank -%}
                <div class="about-value-card">
                  <span class="about-value-card__icon">{{ block.settings[icon_key] }}</span>
                  <h3 class="about-value-card__title">{{ block.settings[title_key] }}</h3>
                  <p class="about-value-card__text">{{ block.settings[text_key] }}</p>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

    {%- when 'cta' -%}
      <div class="about-cta" {{ block.shopify_attributes }}>
        <div class="page-width">
          <h2 class="about-cta__heading">{{ block.settings.heading }}</h2>
          <p class="about-cta__text">{{ block.settings.text }}</p>
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link }}" class="about-cta__button">
              {{ block.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      </div>

  {%- endcase -%}
{%- endfor -%}

