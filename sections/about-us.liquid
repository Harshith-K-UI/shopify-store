{%- style -%}
  .about-us-section {
    padding: 60px 0;
  }

  .about-us-section + .about-us-section {
    padding-top: 0;
  }

  .about-hero {
    text-align: center;
    padding: 80px 0 60px;
  }

  .about-hero__title {
    font-size: 4rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .about-hero__subtitle {
    font-size: 1.4rem;
    font-weight: 400;
    opacity: 0.7;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding: 40px 0;
  }

  .about-grid--reverse {
    direction: rtl;
  }

  .about-grid--reverse > * {
    direction: ltr;
  }

  .about-grid__content {
    padding: 20px 0;
  }

  .about-grid__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 1.1rem;
    font-weight: 600;
    opacity: 0.5;
    margin-bottom: 12px;
  }

  .about-grid__heading {
    font-size: 2.4rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .about-grid__text {
    font-size: 1.5rem;
    line-height: 1.8;
    opacity: 0.8;
  }

  .about-grid__text p {
    margin-bottom: 16px;
  }

  .about-grid__image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }

  .about-grid__image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-values {
    text-align: center;
    padding: 60px 0;
  }

  .about-values__title {
    font-size: 2.4rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 50px;
  }

  .about-values__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .about-value-card {
    padding: 40px 30px;
  }

  .about-value-card__icon {
    font-size: 3rem;
    margin-bottom: 20px;
  }

  .about-value-card__title {
    font-size: 1.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 12px;
  }

  .about-value-card__text {
    font-size: 1.4rem;
    line-height: 1.7;
    opacity: 0.7;
  }

  .about-cta {
    text-align: center;
    padding: 80px 0;
  }

  .about-cta__heading {
    font-size: 2.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 20px;
  }

  .about-cta__text {
    font-size: 1.5rem;
    line-height: 1.7;
    opacity: 0.7;
    max-width: 550px;
    margin: 0 auto 30px;
  }

  .about-cta__button {
    display: inline-block;
    background: #111111;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    font-size: 1.3rem;
    padding: 16px 48px;
    border-radius: 999px;
    text-decoration: none;
    transition: opacity 0.25s ease;
  }

  .about-cta__button:hover {
    opacity: 0.85;
    color: #ffffff;
  }

  @media screen and (max-width: 749px) {
    .about-hero__title {
      font-size: 2.8rem;
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .about-grid--reverse {
      direction: ltr;
    }

    .about-values__grid {
      grid-template-columns: 1fr;
    }

    .about-cta__heading {
      font-size: 2rem;
    }
  }
{%- endstyle -%}

<div class="about-us-section about-hero page-width">
  <h1 class="about-hero__title">{{ section.settings.hero_title }}</h1>
  <p class="about-hero__subtitle">{{ section.settings.hero_subtitle }}</p>
</div>

{%- for block in section.blocks -%}
  {%- case block.type -%}

    {%- when 'story_block' -%}
      <div class="about-us-section page-width" {{ block.shopify_attributes }}>
        <div class="about-grid {% if block.settings.reverse_layout %}about-grid--reverse{% endif %}">
          <div class="about-grid__content">
            <div class="about-grid__eyebrow">{{ block.settings.eyebrow }}</div>
            <h2 class="about-grid__heading">{{ block.settings.heading }}</h2>
            <div class="about-grid__text rte">{{ block.settings.text }}</div>
          </div>
          <div>
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag:
                  class: 'about-grid__image',
                  loading: 'lazy',
                  widths: '400, 600, 800',
                  alt: block.settings.heading
              }}
            {%- else -%}
              <div class="about-grid__image-placeholder">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>

    {%- when 'values' -%}
      <div class="about-us-section page-width" {{ block.shopify_attributes }}>
        <div class="about-values">
          <h2 class="about-values__title">{{ block.settings.heading }}</h2>
          <div class="about-values__grid">
            {%- for i in (1..3) -%}
              {%- assign title_key = 'value_' | append: i | append: '_title' -%}
              {%- assign text_key = 'value_' | append: i | append: '_text' -%}
              {%- assign icon_key = 'value_' | append: i | append: '_icon' -%}
              {%- if block.settings[title_key] != blank -%}
                <div class="about-value-card">
                  <div class="about-value-card__icon">{{ block.settings[icon_key] }}</div>
                  <h3 class="about-value-card__title">{{ block.settings[title_key] }}</h3>
                  <p class="about-value-card__text">{{ block.settings[text_key] }}</p>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

    {%- when 'cta' -%}
      <div class="about-us-section page-width" {{ block.shopify_attributes }}>
        <div class="about-cta">
          <h2 class="about-cta__heading">{{ block.settings.heading }}</h2>
          <p class="about-cta__text">{{ block.settings.text }}</p>
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link }}" class="about-cta__button">
              {{ block.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      </div>

  {%- endcase -%}
{%- endfor -%}

{% schema %}
{
  "name": "About Us",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "Our Story"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Hero subtitle",
      "default": "Born from a passion for anime culture and premium streetwear. We create apparel that lets you wear your fandom with pride."
    }
  ],
  "blocks": [
    {
      "type": "story_block",
      "name": "Story Section",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text",
          "default": "Our Beginning"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Where It All Started"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Content",
          "default": "<p>What began as a simple idea between friends who loved anime and streetwear has grown into a movement. We noticed a gap in the market — anime merch that was either low quality or lacked real design thought. We set out to change that by creating premium apparel that bridges the gap between fandom and fashion.</p><p>Every piece in our collection is designed with intention, printed with care, and made to last. We believe your favorite characters deserve to be represented on clothing you're genuinely proud to wear — whether you're at a convention, on the streets, or just living your everyday life.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "checkbox",
          "id": "reverse_layout",
          "label": "Reverse layout",
          "default": false
        }
      ]
    },
    {
      "type": "values",
      "name": "Values / Mission",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Section heading",
          "default": "What We Stand For"
        },
        {
          "type": "text",
          "id": "value_1_icon",
          "label": "Value 1 icon",
          "default": "🎨"
        },
        {
          "type": "text",
          "id": "value_1_title",
          "label": "Value 1 title",
          "default": "Original Design"
        },
        {
          "type": "textarea",
          "id": "value_1_text",
          "label": "Value 1 description",
          "default": "Every design is original artwork — never generic clip art. Our in-house artists and collaborators bring each piece to life with intentional detail and storytelling."
        },
        {
          "type": "text",
          "id": "value_2_icon",
          "label": "Value 2 icon",
          "default": "✨"
        },
        {
          "type": "text",
          "id": "value_2_title",
          "label": "Value 2 title",
          "default": "Premium Quality"
        },
        {
          "type": "textarea",
          "id": "value_2_text",
          "label": "Value 2 description",
          "default": "We use heavyweight cotton, DTG and screen printing methods, and pre-shrunk fabrics. Our apparel is built to survive washes and keep its shape and color."
        },
        {
          "type": "text",
          "id": "value_3_icon",
          "label": "Value 3 icon",
          "default": "🌍"
        },
        {
          "type": "text",
          "id": "value_3_title",
          "label": "Value 3 title",
          "default": "Community First"
        },
        {
          "type": "textarea",
          "id": "value_3_text",
          "label": "Value 3 description",
          "default": "We're fans first, brand second. Every drop is inspired by conversations with our community. Your feedback shapes what we create next."
        }
      ]
    },
    {
      "type": "cta",
      "name": "Call to Action",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Join the Movement"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Explore our latest collection and find your next statement piece. Every purchase supports independent artists and our growing community."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Us",
      "blocks": [
        {
          "type": "story_block",
          "settings": {
            "eyebrow": "Our Beginning",
            "heading": "Where It All Started"
          }
        },
        {
          "type": "story_block",
          "settings": {
            "eyebrow": "The Founder",
            "heading": "Built by a Fan, for Fans",
            "text": "<p>Hi, I'm the founder of this brand. As a lifelong anime enthusiast and streetwear lover, I saw an opportunity to merge two worlds that rarely intersected well. I started designing from my room, testing prints, perfecting fits, and obsessing over every detail.</p><p>Today, every product still goes through the same obsessive process. I personally approve every design, test every fabric, and wear every piece before it hits the store. This isn't just a business — it's my passion made tangible.</p>",
            "reverse_layout": true
          }
        },
        {
          "type": "story_block",
          "settings": {
            "eyebrow": "Our Process",
            "heading": "Designed with Intention",
            "text": "<p>Our design process starts with the story. What moment, character, or emotion do we want to capture? From there, our artists sketch, iterate, and refine until every line feels right.</p><p>We use DTG (Direct-to-Garment) and screen printing on premium heavyweight cotton. Every color is calibrated, every placement is measured, and every piece is inspected before shipping. We don't cut corners because our community deserves the best.</p>"
          }
        },
        {
          "type": "values"
        },
        {
          "type": "cta"
        }
      ]
    }
  ]
}
{% endschema %}
