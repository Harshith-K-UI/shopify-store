{%- comment -%}
  Scrolling marquee banner — adds streetwear energy.
  Displays repeating brand keywords in an infinite scroll.
{%- endcomment -%}

<div class="tfi-marquee color-{{ section.settings.color_scheme }}">
  <div class="tfi-marquee__inner" aria-hidden="true">
    {%- for i in (1..2) -%}
      <span class="tfi-marquee__item">240 GSM Premium Cotton</span>
      <span class="tfi-marquee__item">DTG Printed in India</span>
      <span class="tfi-marquee__item">Anime Streetwear</span>
      <span class="tfi-marquee__item">Gym Motivation</span>
      <span class="tfi-marquee__item">Oversized Fit</span>
      <span class="tfi-marquee__item">Free Shipping</span>
      <span class="tfi-marquee__item">240 GSM Premium Cotton</span>
      <span class="tfi-marquee__item">DTG Printed in India</span>
      <span class="tfi-marquee__item">Anime Streetwear</span>
      <span class="tfi-marquee__item">Gym Motivation</span>
      <span class="tfi-marquee__item">Oversized Fit</span>
      <span class="tfi-marquee__item">Free Shipping</span>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee Banner",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Marquee Banner"
    }
  ]
}
{% endschema %}
