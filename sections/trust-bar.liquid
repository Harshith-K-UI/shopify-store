{%- comment -%}
  Trust bar — key value propositions in a clean grid.
  Builds credibility and trust for new visitors.
{%- endcomment -%}

<div class="tfi-trust-bar color-{{ section.settings.color_scheme }}">
  <div class="tfi-trust-bar__item">
    <span class="tfi-trust-bar__label">Fabric</span>
    <span class="tfi-trust-bar__value">240 GSM Cotton</span>
  </div>
  <div class="tfi-trust-bar__item">
    <span class="tfi-trust-bar__label">Print</span>
    <span class="tfi-trust-bar__value">DTG Technology</span>
  </div>
  <div class="tfi-trust-bar__item">
    <span class="tfi-trust-bar__label">Origin</span>
    <span class="tfi-trust-bar__value">Made in India</span>
  </div>
  <div class="tfi-trust-bar__item">
    <span class="tfi-trust-bar__label">Delivery</span>
    <span class="tfi-trust-bar__value">Pan-India Shipping</span>
  </div>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Trust Bar"
    }
  ]
}
{% endschema %}
